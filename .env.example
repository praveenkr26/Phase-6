# MongoDB Connection String
# Replace with your actual MongoDB URI
# Option 1: Local MongoDB
MONGO_URI=mongodb://localhost:27017/student_feedback

# Option 2: MongoDB Atlas (Cloud) - Replace with your Atlas URI
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/Phase-6?retryWrites=true&w=majority&appName=Phase06

# Optional non-SRV fallback URI if your network blocks SRV DNS lookups
# MONGO_URI_FALLBACK=mongodb://<username>:<password>@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/student_feedback?replicaSet=<replicaSet>&ssl=true&authSource=admin&retryWrites=true&w=majority

# Server Port
PORT=5000
